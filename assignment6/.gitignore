# venv / build artifacts
.venv/
venv/
*.egg-info/
build/
dist/
__pycache__/
*.pyc

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE / OS
.vscode/
.idea/
.DS_Store

# results / saved_models — opt-in via git add -f
results/
saved_models/*.pt
saved_models/*.pth

# Secrets — Gmail OAuth, App Passwords, Prefect tokens, MCP auth tokens
.env
secrets/
credentials.json
token.json
*.token
*.pem

# Prefect local state
.prefect/

# Logs — gitignored by default to keep training-time noise out of git,
# but assets/logs/ is a SPEC § 7.3 evidence directory and ships in the repo.
*.log
!assets/logs/*.log
