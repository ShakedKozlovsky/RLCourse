# marl-lab environment variables — copy to .env and fill in the secrets.
# V3 § 7.4 — secrets never live in source. `.env` is gitignored.

# === Gmail API integration (§ 5.5) ===
# OPTION A: Google App Password (simpler; requires 2FA on the account).
# Generate at https://myaccount.google.com/apppasswords
MARL_GMAIL_FROM=your.gmail.address@gmail.com
MARL_GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# OPTION B: full OAuth client (download credentials.json from Google Cloud Console,
# place it at ./secrets/credentials.json; first run will create token.json).
# Leave APP_PASSWORD empty to use this path.

# === Submission target ===
MARL_REPORT_TO=rmisegal+marl@gmail.com

# === MCP servers — local development ===
MARL_MCP_COP_HOST=127.0.0.1
MARL_MCP_COP_PORT=7301
MARL_MCP_THIEF_HOST=127.0.0.1
MARL_MCP_THIEF_PORT=7302

# === MCP cloud (Prefect Cloud / FastMCP) ===
# Only set after you've created an account at horizon.prefect.io and minted an API token.
PREFECT_API_KEY=
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/.../workspaces/...

# === Authentication tokens for the public MCP endpoints (§ 5.3) ===
# Comma-separated list of revokable tokens; the cop/thief MCP servers check
# the Authorization header against this list.
MARL_MCP_ALLOWED_TOKENS=demo-token-please-change-me
