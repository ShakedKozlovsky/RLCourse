# Copy to .env and fill in. .env is gitignored.

# Optional: override the default config path used by the SDK.
# FITNESS_RL_CONFIG=configs/setup.json

# Optional: override the global log level (DEBUG, INFO, WARNING, ERROR).
# FITNESS_RL_LOG_LEVEL=INFO

# Optional: pin the data cache directory (default: data/raw).
# FITNESS_RL_DATA_DIR=data/raw

# Optional: Kaggle credentials (only if using the kaggle API instead of manual download).
# KAGGLE_USERNAME=your_kaggle_user
# KAGGLE_KEY=your_kaggle_api_key
