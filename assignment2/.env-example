# Copy to .env and fill in. .env is gitignored.

# Optional: override the default config path used by the SDK.
# DQN_TRADER_CONFIG=configs/setup.json

# Optional: override the rate-limits config path.
# DQN_TRADER_RATE_LIMITS=configs/rate_limits.json

# Optional: override the global log level (DEBUG, INFO, WARNING, ERROR).
# DQN_TRADER_LOG_LEVEL=INFO

# Optional: pin the data cache directory (default: data/raw).
# DQN_TRADER_DATA_CACHE=data/raw
