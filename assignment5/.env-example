# roomba-lab environment variables — copy to .env and fill in
# No secrets are required for this assignment (training is local + CPU-only).
# This file exists to satisfy V3 § 6.2 (config separation + no-secrets-in-source).

# Optional: override the default save root for results / checkpoints
ROOMBA_LAB_RESULTS_DIR=results
ROOMBA_LAB_SAVED_MODELS_DIR=saved_models

# Optional: device override ('cpu' | 'cuda'). Default is 'cpu' — keeps CI reproducible.
ROOMBA_LAB_DEVICE=cpu

# Optional: HouseExpo download mirror. Default is the upstream GitHub release URL.
HOUSE_EXPO_URL=https://github.com/TeaganLi/HouseExpo/raw/master/HouseExpo/json.tar.gz
